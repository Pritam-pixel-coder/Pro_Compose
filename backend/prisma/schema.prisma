generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}



model email_templates {
  id                    Int                     @id @default(autoincrement())
  template_name         String                  @db.VarChar(100)
  email_type            String                  @db.VarChar(50)
  subject_template      String
  opening_template      String?
  body_template         String
  closing_template      String?
  primary_tone          String?                 @db.VarChar(50)
  secondary_tone        String?                 @db.VarChar(50)
  formality_level       String?                 @db.VarChar(20)
  urgency_level         String?                 @db.VarChar(20)
  response_expected     Boolean?                @default(true)
  created_at            DateTime?               @default(now()) @db.Timestamp(6)
  updated_at            DateTime?               @default(now()) @db.Timestamp(6)
  template_phrases      template_phrases[]
  template_placeholders template_placeholders[]
  template_tone_rules   template_tone_rules[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model template_phrases {
  id              Int              @id @default(autoincrement())
  template_id     Int?
  phrase_type     String?          @db.VarChar(20)
  phrase          String
  email_templates email_templates? @relation(fields: [template_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model template_placeholders {
  id               Int              @id @default(autoincrement())
  template_id      Int?
  placeholder_name String           @db.VarChar(50)
  description      String?
  email_templates  email_templates? @relation(fields: [template_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model template_tone_rules {
  id              Int              @id @default(autoincrement())
  template_id     Int?
  characteristic  String
  email_templates email_templates? @relation(fields: [template_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model generated_emails {
  id              Int      @id @default(autoincrement())
  recipient       String?  @db.VarChar(100)
  goal            String
  tone            String?  @db.VarChar(50)
  content         String
  model_used      String?  @db.VarChar(50)
  created_at      DateTime @default(now()) @db.Timestamp(6)
}

